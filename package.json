{
  "name": "easyclip",
  "version": "0.2.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync",
    "dev": "bunx tauri dev",
    "dev:web": "vite dev --port 5173",
    "build": "bunx tauri build",
    "setup:ffmpeg": "bun run scripts/setup-ffmpeg.ts",
    "predev": "bun run setup:ffmpeg",
    "prebuild": "bun run setup:ffmpeg",
    "check": "bun run check:lint && bun run check:format && bun run check:types && bun run check:svelte && bun run check:rust && bun run check:scan && bun run check:versions && bun test --path-ignore-patterns 'tests/wd-*.spec.ts' --path-ignore-patterns 'tests/e2e/*.spec.ts' && bun run scripts/smoke-sidecar.ts",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "check:types": "tsc --noEmit",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "check:rust": "cd src-tauri && cargo check && cargo clippy --all-targets -- -D warnings && cargo fmt --check",
    "check:scan": "bun run scripts/scan-physical-axes.ts && bun run scripts/scan-hardcoded-strings.ts && bun run scripts/scan-no-edit-modes.ts",
    "check:versions": "bun run scripts/check-version-sync.ts",
    "test": "playwright test",
    "test:layer1": "cd src-tauri && cargo test",
    "test:layer2": "wdio run wdio.conf.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.14",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "webdriverio": "^9.27.0"
  },
  "dependencies": {}
}
