{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for EasyClip main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "args": true, "name": "binaries/ffmpeg", "sidecar": true },
        { "args": true, "name": "binaries/ffprobe", "sidecar": true }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "process:default",
    "os:default",
    "store:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}
