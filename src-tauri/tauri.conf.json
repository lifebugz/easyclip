{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyClip",
  "version": "0.1.0",
  "identifier": "com.easyclip.app",
  "build": {
    "beforeDevCommand": "bun run setup:ffmpeg && bun run vite dev --port 5173",
    "beforeBuildCommand": "bun run setup:ffmpeg && bun run vite build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**/*.[mM][pP]4",
            "**/*.[mM][oO][vV]",
            "**/*.[mM]4[vV]",
            "**/*.[mM][kK][vV]",
            "**/*.[wW][eE][bB][mM]",
            "**/*.[aA][vV][iI]",
            "**/*.[wW][mM][vV]",
            "**/*.[fF][lL][vV]",
            "**/*.[mM][pP][gG]",
            "**/*.[mM][pP][eE][gG]",
            "**/*.[tT][sS]",
            "**/*.3[gG][pP]",
            "**/*.3[gG]2",
            "**/*.[mM][tT][sS]",
            "**/*.[mM]2[tT][sS]",
            "**/*.[mM][pP]3",
            "**/*.[mM]4[aA]",
            "**/*.[aA][aA][cC]",
            "**/*.[wW][aA][vV]",
            "**/*.[fF][lL][aA][cC]",
            "**/*.[oO][gG][gG]",
            "**/*.[oO][pP][uU][sS]"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'"
    },
    "windows": [
      {
        "label": "main",
        "title": "EasyClip",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "category": "Video",
    "shortDescription": "Lossless desktop media trimmer",
    "longDescription": "EasyClip is a step-by-step wizard for trimming video and audio files without learning complex software. All cuts are lossless via FFmpeg stream-copy and concat-demuxer."
  }
}
